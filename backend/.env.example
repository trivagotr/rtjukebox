# Production Environment Variables
PORT=3000
NODE_ENV=production

# Database
# For Docker: postgres://user:password@db:5432/radiotedu
# For Native Windows: postgres://postgres:your_password@localhost:5432/radiotedu
DATABASE_URL=postgres://user:password@localhost:5432/radiotedu

# Redis
# For Docker: redis://redis:6379
# For Native Windows: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

# External APIs
WORDPRESS_API_URL=https://radiotedu.com/wp-json/wp/v2
PODCAST_CATEGORY_ID=
RADIO_STREAM_URL=https://stream.radiotedu.com/live

# Background podcast RSS sync interval in hours (default 6)
PODCAST_SYNC_INTERVAL_HOURS=6

# Radio now-playing history watcher (optional).
# JSON array of { "channelId", "metadataUrl" }. Leave unset to keep the watcher idle.
# RADIO_HISTORY_SOURCES=[{"channelId":"main","metadataUrl":"https://stream.radiotedu.com/status-json.xsl"}]

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/v1/spotify/callback

# CORS
# Comma-separated allowlist of browser origins for the controller/kiosk apps.
# Required when NODE_ENV=production.
CORS_ORIGINS=https://controller.example.com,https://kiosk.example.com
