<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Automotive build variant: Android Automotive OS only surfaces a media
         app in the car when it requires the automotive feature. This overrides
         the main manifest's required="false" for the automotive flavor only;
         the mobile flavor stays installable on phones/tablets. -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="true"
        tools:replace="android:required" />

</manifest>
